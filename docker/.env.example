# Copy to docker/.env and adjust as needed. Never commit the real .env.
#
# COMPOSE_PROJECT_NAME is critical when this repo shares a VPS with another
# Docker Compose stack: Compose otherwise auto-names a project after the
# current directory's basename, and both this repo's and the LMS's compose
# files live in a folder literally called "docker/" — without this, both
# stacks default to the *same* project name and their containers/volumes
# collide (this happened once in practice: bringing this stack up silently
# replaced the LMS's production containers because both resolved to
# "docker-php-1" etc.). Keep this set, never remove it.
COMPOSE_PROJECT_NAME=gstlab
HTTP_PORT=8090
DB_PORT=3307
DB_NAME=gstportal
DB_USER=gstportal
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root
APP_BASE_URL=https://gstlab.practicaleduskills.com/

# Gmail SMTP for registration/approval/password-reset emails. Use a Gmail
# "App Password" (Google Account > Security > 2-Step Verification > App
# passwords), never the account's real login password.
SMTP_USER=gsteducationportal@gmail.com
SMTP_PASS=change_me
